#!/usr/bin/env bash
# bin/setup — prepare a working mlx-rb development checkout.
#
# Production users install the precompiled platform gem
# (`gem install mlx-rb`) which has no toolchain requirements. This
# script is for *developing* mlx-rb itself, which needs Rust to build
# the bridge crate.
set -euo pipefail

GEM_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$GEM_ROOT"

step() { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
fail() { printf '\033[1;31m!! %s\033[0m\n' "$*" >&2; exit 1; }

step "Detecting host platform..."
OS="$(uname -s)"
ARCH="$(uname -m)"
[ "$OS" = "Darwin" ] || fail "mlx-rb runs on macOS only (detected $OS)."
[ "$ARCH" = "arm64" ] || fail "mlx-rb requires Apple Silicon (detected $ARCH)."
echo "  $OS / $ARCH ✓"

step "Checking Xcode toolchain..."
xcode-select -p >/dev/null 2>&1 || fail "Xcode Command Line Tools not installed. Run: xcode-select --install"
echo "  $(xcode-select -p) ✓"

step "Checking Rust toolchain..."
if ! command -v cargo >/dev/null 2>&1; then
  fail "cargo not on PATH. Install via https://rustup.rs/ or:  brew install rust"
fi
echo "  $(cargo --version) ✓"

step "Running bundle install..."
bundle install

step "Building the Rust bridge (cargo build --release)..."
bundle exec rake compile

step "Smoke test: require \"mlx\" and run a 2x2 matmul..."
bundle exec ruby -Ilib -rmlx -e '
  raise "platform check failed" unless MLX.platform_supported?
  a = MLX::Array.new([[1.0, 2.0], [3.0, 4.0]])
  b = MLX::Array.ones([2, 2])
  out = a.matmul(b).to_a
  expected = [[3.0, 3.0], [7.0, 7.0]]
  raise "matmul mismatch: #{out.inspect}" unless out == expected
  puts "  matmul OK; default device = #{MLX.default_device}"
'

step "Setup complete."
