#!/usr/bin/env bash
# bin/setup — prepare a working mlx-rb checkout.
#
# Steps:
#   1. Verify host is macOS arm64. Fail with a clear message otherwise.
#   2. Verify Xcode CLT and CMake are present.
#   3. bundle install.
#   4. Build mlx-c into ext/mlx_c/upstream/build if libmlxc.dylib is
#      missing.
#   5. Run a require-time smoke test.
set -euo pipefail

GEM_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$GEM_ROOT"

step() { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
fail() { printf '\033[1;31m!! %s\033[0m\n' "$*" >&2; exit 1; }

step "Detecting host platform..."
OS="$(uname -s)"
ARCH="$(uname -m)"
if [ "$OS" != "Darwin" ]; then
  fail "mlx-rb runs on macOS only (detected $OS). MLX is built on Apple Silicon's Metal backend; there is no Linux build."
fi
if [ "$ARCH" != "arm64" ]; then
  fail "mlx-rb requires Apple Silicon (M-series). Detected arch: $ARCH. Intel Macs are not supported."
fi
echo "  macOS $OS / $ARCH ✓"

step "Checking Xcode Command Line Tools..."
if ! xcode-select -p >/dev/null 2>&1; then
  fail "Xcode Command Line Tools not installed. Run:  xcode-select --install"
fi
echo "  $(xcode-select -p) ✓"

step "Checking CMake..."
if ! command -v cmake >/dev/null 2>&1; then
  fail "cmake not on PATH. Install with:  brew install cmake"
fi
echo "  $(cmake --version | head -1) ✓"

step "Running bundle install..."
bundle install

LIB_DIR="$GEM_ROOT/ext/mlx_c/upstream/build"
LIB_PATH="$LIB_DIR/libmlxc.dylib"
if [ ! -f "$LIB_PATH" ]; then
  step "libmlxc.dylib missing; building from vendored mlx-c source..."
  if [ ! -d "$GEM_ROOT/ext/mlx_c/upstream" ]; then
    fail "ext/mlx_c/upstream is missing. Did you clone with --recursive?"
  fi
  mkdir -p "$LIB_DIR"
  cmake -S "$GEM_ROOT/ext/mlx_c/upstream" -B "$LIB_DIR" -DCMAKE_BUILD_TYPE=Release >/dev/null
  cmake --build "$LIB_DIR" --parallel
  [ -f "$LIB_PATH" ] || fail "Build finished but $LIB_PATH was not produced."
fi
echo "  $LIB_PATH ✓"

step "Smoke test: require \"mlx\" and run a 2x2 matmul..."
bundle exec ruby -Ilib -rmlx -e '
  raise "platform check failed" unless MLX.platform_supported?
  a = MLX::Array.new([[1.0, 2.0], [3.0, 4.0]])
  b = MLX::Array.ones([2, 2])
  out = a.matmul(b).to_a
  expected = [[3.0, 3.0], [7.0, 7.0]]
  raise "matmul mismatch: #{out.inspect}" unless out == expected
  puts "  matmul OK; default device = #{MLX.default_device}"
'

step "Setup complete."
